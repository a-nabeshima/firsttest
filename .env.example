# AWS 認証情報（IAM ユーザー or 環境ロールで設定済みの場合は不要）
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-northeast-1

# Bedrock モデル ID（Claude 3.5 Sonnet 推奨）
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Enterprise Architect MCP コマンド
# 公式 Sparx Systems MCP3.exe（EA インストール済みの場合）:
EA_MCP_COMMAND="C:\\Program Files\\SparxSystems Japan\\EA\\MCP_Server\\MCP3.exe"
#
# コミュニティ版 Python サーバー（ea_mcp パッケージ）:
# EA_MCP_COMMAND=python -m ea_mcp.server
